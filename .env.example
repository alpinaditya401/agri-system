APP_NAME=Agrilink
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agri_system
DB_USERNAME=root
DB_PASSWORD=
# TiDB Cloud biasanya memakai port 4000 dan SSL CA.
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

BPS_API_BASE_URL=https://webapi.bps.go.id/v1/api
BPS_API_DOMAIN=0000
BPS_API_KEY=
BPS_API_TIMEOUT=30
CORS_ALLOWED_ORIGINS=*
CORS_SUPPORTS_CREDENTIALS=false

PAYMENT_GATEWAY=midtrans
PAYMENT_WEBHOOK_GATEWAY=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com
XENDIT_CALLBACK_TOKEN=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@agrilink.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
