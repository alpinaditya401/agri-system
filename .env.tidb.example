APP_NAME=Agrilink
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-vercel-or-domain-url

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_DATABASE=agri_system
DB_USERNAME=your_tidb_username
DB_PASSWORD=your_tidb_password
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

BPS_API_BASE_URL=https://webapi.bps.go.id/v1/api
BPS_API_DOMAIN=0000
BPS_API_KEY=your_bps_api_key
BPS_API_TIMEOUT=30

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@agrilink.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
